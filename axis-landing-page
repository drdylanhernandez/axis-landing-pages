    </div>
    <p class="modal-note">🔒 Your info is already saved. Just pick your time on the next page.</p>
  </div>
</div>

<div class="utm-badge" id="utmBadge"></div>

<script>
/* ── UTM ── */
const params = new URLSearchParams(window.location.search);
const src = params.get('src') || params.get('utm_content') || null;
const camp = params.get('utm_campaign') || null;

const srcMap = {
  'ig-why':   'Instagram Ad — Why Hook',
  'ig-fedup': 'Instagram Ad — Fed Up Hook',
  'ig-diff':  'Instagram Ad — Differentiation Hook',
  'ig-perf':  'Instagram Ad — Performance Hook',
  'ig-offer': 'Instagram Ad — Offer Hook',
};
const dropMap = {
  'ig-why':   'Instagram',
  'ig-fedup': 'Instagram',
  'ig-diff':  'Instagram',
  'ig-perf':  'Instagram',
  'ig-offer': 'Instagram',
};

let resolvedSource = srcMap[src] || (src ? decodeURIComponent(src) : null);
let leadData = {};

if (resolvedSource) {
  const sel = document.getElementById('fSrc');
  if (dropMap[src]) sel.value = dropMap[src];
  const badge = document.getElementById('utmBadge');
  badge.textContent = '📲 ' + resolvedSource;
  setTimeout(() => badge.classList.add('show'), 900);
  setTimeout(() => badge.classList.remove('show'), 5500);
}

/* ── WEBHOOK ── */
/* REPLACE with your Zapier or Make.com webhook URL */
const WEBHOOK = 'YOUR_ZAPIER_OR_MAKE_WEBHOOK_URL_HERE';

async function fireWebhook(payload) {
  if (WEBHOOK === 'YOUR_ZAPIER_OR_MAKE_WEBHOOK_URL_HERE') {
    console.log('📋 Webhook payload (demo):', payload);
    return true;
  }
  try {
    await fetch(WEBHOOK, {
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify(payload),
      mode:'no-cors',
    });
    return true;
  } catch(e) {
    console.warn('Webhook error:', e);
    return false;
  }
}

/* ── SUBMIT FORM ── */
async function submitLead() {
  const btn = document.getElementById('fBtn');
  const first  = document.getElementById('fFirst').value.trim();
  const last   = document.getElementById('fLast').value.trim();
  const phone  = document.getElementById('fPhone').value.trim();
  const email  = document.getElementById('fEmail').value.trim();
  const loc    = document.getElementById('fLoc').value;
  const source = document.getElementById('fSrc').value;

  if (!first || !last || !phone || !email || !loc) {
    alert('Please fill out all required fields.');
    return;
  }

  btn.disabled = true;
  btn.textContent = 'Sending...';

  leadData = {
    firstName: first, lastName: last, phone, email,
    location: loc,
    source: source || resolvedSource || 'Unknown',
    utmSrc: src || '', utmCampaign: camp || '',
    event: 'form_submit',
    page: window.location.href,
    timestamp: new Date().toISOString(),
  };

  /* Fire webhook: new lead alert */
  await fireWebhook(leadData);

  document.getElementById('fFields').style.display = 'none';
  document.getElementById('fSuccess').style.display = 'block';
}

/* ── OPEN SCHEDULING MODAL ── */
function goSchedule() {
  document.getElementById('schedModal').classList.add('open');
}

function closeModal() {
  document.getElementById('schedModal').classList.remove('open');
}

/* Close on overlay click */
document.getElementById('schedModal').addEventListener('click', function(e) {
  if (e.target === this) closeModal();
});

/* ── TRACK SCHEDULING CLICK + FIRE SECOND ALERT ── */
async function trackScheduleClick(location) {
  const payload = {
    ...leadData,
    event: 'schedule_click',
    schedulingLocation: location,
    timestamp: new Date().toISOString(),
  };
  /* Second webhook ping: patient clicked to schedule — you get notified */
  await fireWebhook(payload);
  /* Don't prevent default — let the link open */
}

/* ── SCROLL REVEAL ── */
const obs = new IntersectionObserver((entries) => {
  entries.forEach((e, i) => {
    if (e.isIntersecting) {
      setTimeout(() => e.target.classList.add('vis'), i * 55);
      obs.unobserve(e.target);
    }
  });
}, { threshold: 0.08 });
document.querySelectorAll('.reveal').forEach(el => obs.observe(el));

/* ── FAQ ── */
function faq(btn) {
  const item = btn.closest('.faq-item');
  const open = item.classList.contains('open');
  document.querySelectorAll('.faq-item.open').forEach(el => el.classList.remove('open'));
  if (!open) item.classList.add('open');
}

/* ── UTM on schedule links ── */
const utmSuffix = src ? `?utm_source=instagram&utm_medium=paid&utm_content=${src}` : '';
if (utmSuffix) {
  document.querySelectorAll('a[href*="locations-schedule"]').forEach(a => {
    if (!a.href.includes('utm_source')) a.href += utmSuffix;
  });
}
</script>
</body>
</html>
