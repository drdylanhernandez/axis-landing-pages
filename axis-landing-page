<style>
:root {
  --bg:       #0a0b0d;
  --bg2:      #0f1115;
  --surface:  #141619;
  --border:   #1f2228;
  --gold:     #e5be5e;
  --gold-dim: rgba(229,190,94,0.10);
  --gold-bdr: rgba(229,190,94,0.22);
  --silver:   #c8cdd6;
  --warm:     #f0ece4;
  --white:    #ffffff;
  --muted:    #717a8a;
  --dark-txt: #0a0b0d;
}

*, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
html { scroll-behavior:smooth; }

body {
  background: var(--bg);
  color: var(--warm);
  font-family: 'Barlow', sans-serif;
  overflow-x: hidden;
}

/* noise overlay */
body::before {
  content:'';
  position:fixed; inset:0;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.035'/%3E%3C/svg%3E");
  pointer-events:none; z-index:999; opacity:.45;
}

/* ── TOPBAR ── */
.topbar {
  background: var(--gold);
  color: var(--dark-txt);
  text-align:center;
  padding:.65rem 1rem;
  font-family:'Barlow Condensed',sans-serif;
  font-weight:700; font-size:1rem;
  letter-spacing:.14em; text-transform:uppercase;
}

/* ── NAV ── */
nav {
  display:flex; align-items:center; justify-content:space-between;
  padding:1rem 5vw;
  border-bottom:1px solid var(--border);
  position:sticky; top:0;
  background:rgba(10,11,13,.96);
  backdrop-filter:blur(14px);
  z-index:100;
}

.nav-logo img { height:52px; width:auto; display:block; }

.nav-links { display:flex; align-items:center; gap:2rem; list-style:none; }
.nav-links a {
  color:var(--muted); text-decoration:none;
  font-size:1rem; font-weight:500; letter-spacing:.04em;
  transition:color .2s;
}
.nav-links a:hover { color:var(--warm); }

.nav-cta {
  background:var(--gold) !important;
  color:var(--dark-txt) !important;
  padding:.6rem 1.5rem;
  border-radius:3px;
  font-family:'Barlow Condensed',sans-serif !important;
  font-weight:900 !important;
  letter-spacing:.1em !important;
  text-transform:uppercase;
  font-size:1rem !important;
  transition:filter .2s !important;
  white-space:nowrap;
}
.nav-cta:hover { filter:brightness(1.12); }

@media(max-width:640px){ .nav-links { display:none; } }

/* ── HERO ── */
.hero {
  position:relative;
  min-height:94vh;
  display:flex; align-items:center;
  padding:20rem 5vw 4rem;
  overflow:hidden;
}

.hero-grid-bg {
  position:absolute; inset:0;
  background-image:
    linear-gradient(rgba(229,190,94,.035) 1px, transparent 1px),
    linear-gradient(90deg,rgba(229,190,94,.035) 1px, transparent 1px);
  background-size:64px 64px;
  mask-image:radial-gradient(ellipse 90% 90% at 50% 50%,black 20%,transparent 100%);
}

.hero-glow {
  position:absolute; top:-15%; right:-8%;
  width:680px; height:680px;
  background:radial-gradient(circle,rgba(229,190,94,.07) 0%,transparent 65%);
  pointer-events:none;
}

.hero-inner {
  position:relative; z-index:2;
  max-width:1140px; width:100%; margin:0 auto;
  display:grid; grid-template-columns:1fr 390px; gap:4rem; align-items:center;
}

.hero-eyebrow {
  display:inline-flex; align-items:center; gap:.5rem;
  background:var(--gold-dim); border:1px solid var(--gold-bdr);
  border-radius:2px; padding:.45rem 1.1rem;
  margin-bottom:1.4rem;
  animation:fadeUp .6s ease both;
}
.hero-eyebrow-dot {
  width:8px; height:8px; background:var(--gold); border-radius:50%;
  box-shadow:0 0 8px var(--gold); animation:pulse 2s infinite;
}
.hero-eyebrow-text {
  font-family:'Barlow Condensed',sans-serif;
  font-size:1.1rem; font-weight:700; letter-spacing:.14em; text-transform:uppercase;
  color:var(--gold);
}
@keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.5;transform:scale(.8)} }

.hero-hl {
  font-family:'Barlow Condensed',sans-serif;
  font-weight:900;
  font-size:clamp(3.6rem,7.5vw,6.8rem);
  line-height:.9; text-transform:uppercase; letter-spacing:-.01em;
  color:var(--white); margin-bottom:1.4rem;
  animation:fadeUp .7s .1s ease both;
}
.hero-hl .gold  { color:var(--gold); }
.hero-hl .it    { font-style:italic; font-weight:700; }
.hero-hl .silver{ color:var(--silver); }

.hero-sub {
  font-size:1.12rem; line-height:1.72;
  color:rgba(240,236,228,.68);
  max-width:500px; margin-bottom:2.5rem;
  animation:fadeUp .7s .2s ease both;
}

.hero-btns {
  display:flex; align-items:center; gap:1rem; flex-wrap:wrap;
  animation:fadeUp .7s .3s ease both;
}

.btn-gold {
  background:var(--gold); color:var(--dark-txt);
  padding:1rem 2.2rem;
  font-family:'Barlow Condensed',sans-serif;
  font-weight:900; font-size:1rem; letter-spacing:.12em; text-transform:uppercase;
  border:none; border-radius:3px; cursor:pointer; text-decoration:none;
  display:inline-block; transition:all .2s;
  box-shadow:0 0 28px rgba(229,190,94,.22);
}
.btn-gold:hover { filter:brightness(1.1); box-shadow:0 0 48px rgba(229,190,94,.38); transform:translateY(-1px); }

.btn-ghost {
  color:var(--warm); padding:1rem 1.5rem;
  font-family:'Barlow Condensed',sans-serif;
  font-weight:700; font-size:.9rem; letter-spacing:.1em; text-transform:uppercase;
  text-decoration:none; border:1px solid var(--border); border-radius:3px;
  transition:all .2s;
}
.btn-ghost:hover { border-color:var(--gold-bdr); color:var(--gold); }

/* ── PRICE CARD ── */
.price-card {
  background:var(--surface); border:1px solid var(--border);
  border-radius:8px; padding:2rem;
  position:relative; overflow:hidden;
  animation:fadeUp .8s .4s ease both;
}
.price-card::before {
  content:''; position:absolute; top:0; left:0; right:0; height:2px;
  background:linear-gradient(90deg,var(--gold),transparent);
}

.price-triangles {
  display:flex; gap:.4rem; margin-bottom:1.2rem; align-items:center;
}
.price-triangles img { height:78px; width:auto; }
.gold-tri-accent { height:65px; width:auto; margin-bottom:1rem; display:block; }
.loc-tri { height:14px; width:auto; }

.price-lbl {
  font-family:'Barlow Condensed',sans-serif;
  font-size:1.1rem; font-weight:700; letter-spacing:.18em; text-transform:uppercase;
  color:var(--gold); margin-bottom:.75rem;
}
.price-amt {
  font-family:'Barlow Condensed',sans-serif;
  font-weight:900; font-size:5rem; line-height:1; color:var(--white); margin-bottom:.2rem;
}
.price-amt sup { font-size:2.4rem; vertical-align:super; }
.price-was { font-size:.78rem; color:var(--muted); text-decoration:line-through; margin-bottom:1.5rem; }

.price-list { list-style:none; display:flex; flex-direction:column; gap:.6rem; margin-bottom:1.5rem; }
.price-list li {
  display:flex; align-items:flex-start; gap:.6rem;
  font-size:1.05rem; color:rgba(240,236,228,.85); line-height:1.4;
}
.chk { color:var(--gold); flex-shrink:0; margin-top:.05rem; }

.price-cta-btn {
  width:100%; display:block; text-align:center;
  background:var(--gold); color:var(--dark-txt);
  padding:1rem;
  font-family:'Barlow Condensed',sans-serif;
  font-weight:900; font-size:1rem; letter-spacing:.12em; text-transform:uppercase;
  border-radius:3px; text-decoration:none; transition:all .2s;
  box-shadow:0 0 18px rgba(229,190,94,.15);
}
.price-cta-btn:hover { filter:brightness(1.1); box-shadow:0 0 36px rgba(229,190,94,.3); }
.price-note { text-align:center; font-size:.85rem; color:var(--muted); margin-top:.7rem; }

@media(max-width:900px){
  .hero-inner { grid-template-columns:1fr; gap:2.5rem; }
  .price-card { max-width:400px; }
}

/* ── SECTIONS ── */
section { padding:5.5rem 5vw; }
.sec-inner { max-width:1140px; margin:0 auto; }

.angle-dn {
  height:72px; background:var(--bg2);
  clip-path:polygon(0 0,100% 36px,100% 100%,0 100%);
  margin-top:-1px;
}
.angle-up {
  height:72px; background:var(--bg);
  clip-path:polygon(0 36px,100% 0,100% 100%,0 100%);
  margin-top:-1px;
}

.sec-eye {
  font-family:'Barlow Condensed',sans-serif;
  font-size:1.1rem; font-weight:700; letter-spacing:.18em; text-transform:uppercase;
  color:var(--gold); margin-bottom:.75rem;
}
.sec-hl {
  font-family:'Barlow Condensed',sans-serif;
  font-weight:900;
  font-size:clamp(2rem,4vw,3.2rem);
  text-transform:uppercase; line-height:.95; color:var(--white);
  margin-bottom:1.25rem;
}
.sec-hl .it { font-style:italic; color:var(--gold); }
.sec-hl .sv { color:var(--silver); }

/* ── TESTIMONIALS ── */
.testimonials-sec {
  background:var(--bg2);
  padding:5.5rem 5vw;
}

.testimonials-grid {
  display:grid;
  grid-template-columns:repeat(3, 1fr);
  gap:1.25rem;
  margin-top:2.5rem;
  margin-bottom:2.5rem;
}

.testimonial-card {
  background:var(--surface);
  border:1px solid var(--border);
  border-radius:8px;
  padding:1.75rem;
  display:flex;
  flex-direction:column;
  gap:1rem;
  position:relative;
  transition:border-color .2s;
}

.testimonial-card::before {
  content:'';
  position:absolute; top:0; left:0; right:0; height:2px;
  background:linear-gradient(90deg, var(--gold), transparent);
  border-radius:8px 8px 0 0;
}

.testimonial-card:hover { border-color:var(--gold-bdr); }

.testimonial-stars {
  color:var(--gold);
  font-size:1rem;
  letter-spacing:.1em;
}

.testimonial-text {
  font-size:1rem;
  line-height:1.72;
  color:rgba(240,236,228,.82);
  flex:1;
  font-style:italic;
}

.testimonial-author { margin-top:.5rem; }

.testimonial-name {
  font-family:'Barlow Condensed', sans-serif;
  font-weight:700;
  font-size:1rem;
  letter-spacing:.06em;
  text-transform:uppercase;
  color:var(--white);
}

.testimonial-meta {
  font-size:.78rem;
  color:var(--muted);
  margin-top:.15rem;
}

.testimonials-rating {
  text-align:center;
  padding-top:2rem;
  border-top:1px solid var(--border);
  display:flex;
  flex-direction:column;
  align-items:center;
  gap:.5rem;
}

.testimonials-stars-lg {
  color:var(--gold);
  font-size:1.5rem;
  letter-spacing:.15em;
}

.testimonials-rating-text {
  font-family:'Barlow Condensed', sans-serif;
  font-size:.85rem;
  font-weight:600;
  letter-spacing:.14em;
  text-transform:uppercase;
  color:var(--muted);
}

@media(max-width:900px){
  .testimonials-grid { grid-template-columns:1fr; }
}
@media(min-width:601px) and (max-width:900px){
  .testimonials-grid { grid-template-columns:1fr 1fr; }
}
.prob-sec { background:var(--bg2); position:relative; overflow:hidden; }
.prob-photo-bg {
  position:absolute; inset:0; z-index:0;
}
.prob-photo-bg img {
