  font-weight:700; font-size:.88rem; letter-spacing:.1em; text-transform:uppercase;
  color:rgba(240,236,228,.8);
  opacity:0; transform:translateY(6px); transition:all .3s;
}

.gallery-item:hover .gallery-caption { opacity:1; transform:none; }

@media(max-width:640px){
  .gallery-grid { grid-template-columns:1fr; }
  .gallery-item img { height:240px; }
}

