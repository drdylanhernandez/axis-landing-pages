}
.prob-card {
  background:var(--surface); border:1px solid var(--border);
  border-radius:6px; padding:1.4rem; transition:border-color .2s;
}
.prob-card:hover { border-color:var(--gold-bdr); }
.prob-icon { font-size:1.5rem; margin-bottom:.65rem; }
.prob-title {
  font-family:'Barlow Condensed',sans-serif;
  font-weight:700; font-size:1.15rem; letter-spacing:.05em; text-transform:uppercase;
  color:var(--white); margin-bottom:.4rem;
}
.prob-desc { font-size:1.05rem; line-height:1.68; color:var(--muted); }

/* ── SOLUTION ── */
.sol-sec { background:var(--bg); }
.sol-grid { display:grid; grid-template-columns:1fr 1fr; gap:3.5rem; align-items:center; margin-top:2.5rem; }

.svc-list { display:flex; flex-direction:column; gap:.9rem; }
.svc-item {
  display:flex; align-items:flex-start; gap:.9rem;
  padding:1.1rem 1.25rem;
  background:var(--surface); border:1px solid var(--border);
  border-radius:6px; transition:border-color .2s,transform .2s;
}
.svc-item:hover { border-color:var(--gold-bdr); transform:translateX(4px); }
.svc-icon {
  width:36px; height:36px; flex-shrink:0;
  background:var(--gold-dim); border:1px solid var(--gold-bdr);
  border-radius:4px; display:flex; align-items:center; justify-content:center;
  font-size:1rem;
}
.svc-name {
  font-family:'Barlow Condensed',sans-serif;
  font-weight:700; font-size:1.1rem; letter-spacing:.05em; text-transform:uppercase;
  color:var(--white); margin-bottom:.2rem;
}
.svc-desc { font-size:1.05rem; color:var(--muted); line-height:1.6; }

