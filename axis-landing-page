}
.hero-logo-eyebrow {
  display:inline-flex; align-items:center; gap:.5rem;
  background:var(--gold-dim); border:1px solid var(--gold-bdr);
  border-radius:2px; padding:.45rem 1.1rem;
  pointer-events:all;
  margin-bottom:1rem;
}
