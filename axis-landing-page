  display:block; filter:brightness(.6) saturate(.85); transition:transform .6s ease;
}
.book-split:hover .book-photo img { transform:scale(1.02); }
.book-photo-overlay {
  position:absolute; inset:0; display:flex; align-items:flex-end; padding:2rem;
